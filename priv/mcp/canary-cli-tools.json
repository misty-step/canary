{
  "schema_version": 1,
  "tools": [
    {
      "description": "Inspect global Canary status for a query window.",
      "input_schema": {
        "properties": {
          "window": {
            "enum": [
              "1h",
              "6h",
              "24h",
              "7d",
              "30d"
            ],
            "type": "string"
          }
        },
        "type": "object"
      },
      "name": "canary_summary"
    },
    {
      "description": "Inspect recent error groups for one service.",
      "input_schema": {
        "properties": {
          "service": {
            "type": "string"
          },
          "window": {
            "enum": [
              "1h",
              "6h",
              "24h",
              "7d",
              "30d"
            ],
            "type": "string"
          }
        },
        "required": [
          "service"
        ],
        "type": "object"
      },
      "name": "canary_errors"
    },
    {
      "description": "Run the agent-oriented Canary doctor check.",
      "input_schema": {
        "properties": {},
        "type": "object"
      },
      "name": "canary_doctor"
    },
    {
      "description": "List remediation claims for one Canary subject.",
      "input_schema": {
        "properties": {
          "cursor": {
            "type": "string"
          },
          "limit": {
            "maximum": 50,
            "minimum": 1,
            "type": "integer"
          },
          "subject_id": {
            "type": "string"
          },
          "subject_type": {
            "enum": [
              "incident",
              "error_group",
              "target",
              "monitor"
            ],
            "type": "string"
          }
        },
        "required": [
          "subject_type",
          "subject_id"
        ],
        "type": "object"
      },
      "name": "canary_claims_list"
    },
    {
      "description": "Read one remediation claim by id.",
      "input_schema": {
        "properties": {
          "claim_id": {
            "type": "string"
          }
        },
        "required": [
          "claim_id"
        ],
        "type": "object"
      },
      "name": "canary_claim_get"
    },
    {
      "description": "Claim one Canary subject for agentic remediation with owner, purpose, TTL, and idempotency key.",
      "input_schema": {
        "properties": {
          "evidence_links": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "idempotency_key": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "subject_id": {
            "type": "string"
          },
          "subject_type": {
            "enum": [
              "incident",
              "error_group",
              "target",
              "monitor"
            ],
            "type": "string"
          },
          "ttl_ms": {
            "minimum": 1,
            "type": "integer"
          }
        },
        "required": [
          "subject_type",
          "subject_id",
          "owner",
          "purpose",
          "ttl_ms",
          "idempotency_key"
        ],
        "type": "object"
      },
      "name": "canary_claim_create"
    },
    {
      "description": "Transition one remediation claim to a bounded state.",
      "input_schema": {
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "evidence_links": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "owner": {
            "type": "string"
          },
          "state": {
            "enum": [
              "claimed",
              "investigating",
              "fix_proposed",
              "verified",
              "dismissed",
              "expired",
              "released"
            ],
            "type": "string"
          }
        },
        "required": [
          "claim_id",
          "owner",
          "state"
        ],
        "type": "object"
      },
      "name": "canary_claim_transition"
    },
    {
      "description": "Release one remediation claim.",
      "input_schema": {
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          }
        },
        "required": [
          "claim_id",
          "owner"
        ],
        "type": "object"
      },
      "name": "canary_claim_release"
    },
    {
      "description": "Discover local project integration state without reading secret values.",
      "input_schema": {
        "properties": {
          "path_or_project": {
            "type": "string"
          },
          "platform_project": {
            "type": "string"
          },
          "production_url": {
            "type": "string"
          },
          "service": {
            "type": "string"
          }
        },
        "required": [
          "path_or_project"
        ],
        "type": "object"
      },
      "name": "canary_integrate_discover"
    },
    {
      "description": "Merge local scan, integration receipt, live Canary state, query readback, webhooks, and dogfood evidence into one coverage verdict.",
      "input_schema": {
        "properties": {
          "path_or_project": {
            "type": "string"
          },
          "platform_project": {
            "type": "string"
          },
          "production_url": {
            "type": "string"
          },
          "service": {
            "type": "string"
          }
        },
        "required": [
          "path_or_project"
        ],
        "type": "object"
      },
      "name": "canary_integrate_status"
    },
    {
      "description": "Emit a reviewable Canary integration patch and enrollment plan.",
      "input_schema": {
        "properties": {
          "path_or_project": {
            "type": "string"
          },
          "platform_project": {
            "type": "string"
          },
          "production_url": {
            "type": "string"
          },
          "service": {
            "type": "string"
          }
        },
        "required": [
          "path_or_project"
        ],
        "type": "object"
      },
      "name": "canary_integrate_plan"
    },
    {
      "description": "Apply safe Next.js Canary integration patches after reviewing the plan.",
      "input_schema": {
        "properties": {
          "path_or_project": {
            "type": "string"
          },
          "platform_project": {
            "type": "string"
          },
          "production_url": {
            "type": "string"
          },
          "service": {
            "type": "string"
          }
        },
        "required": [
          "path_or_project"
        ],
        "type": "object"
      },
      "name": "canary_integrate_patch"
    },
    {
      "description": "Create a Canary health target and scoped ingest key for a deployed service; redacts the one-time key by default.",
      "input_schema": {
        "properties": {
          "environment": {
            "type": "string"
          },
          "interval_ms": {
            "type": "integer"
          },
          "project_root": {
            "type": "string"
          },
          "service": {
            "type": "string"
          },
          "show_secret": {
            "default": false,
            "type": "boolean"
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "service",
          "url"
        ],
        "type": "object"
      },
      "name": "canary_integrate_enroll"
    }
  ]
}

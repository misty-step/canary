{
  "name": "canary-typescript-reference",
  "version": "0.0.0",
  "description": "Source-only TypeScript instrumentation reference for Canary's HTTP API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js",
      "require": "./dist/nextjs.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misty-step/canary.git",
    "directory": "clients/typescript"
  },
  "homepage": "https://github.com/misty-step/canary/blob/master/clients/typescript/INTEGRATION.md",
  "bugs": {
    "url": "https://github.com/misty-step/canary/issues"
  },
  "keywords": [
    "canary",
    "error-tracking",
    "observability",
    "nextjs",
    "monitoring",
    "http-api",
    "reference"
  ],
  "author": "Misty Step",
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15"
  }
}

# Keep the Docker build context to what the Dockerfile actually COPYs
# (Cargo.toml, Cargo.lock, crates/, priv/, litestream.yml, bin/). Without this
# file a full-history release checkout can send the entire .git directory to
# the builder.
.git
.github
.githooks
.ci
.claude
.agents
.codex
docs
site
test
dagger
clients
target
canary.db*
*.md

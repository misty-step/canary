#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fixture="$repo_root/crates/canary-store/tests/fixtures/phoenix_schema.db"
populated_fixture="$repo_root/crates/canary-store/tests/fixtures/phoenix_read_models.db"
test_partition="_rust_fixture"
test_db="$repo_root/canary_test${test_partition}.db"

cd "$repo_root"

checkpoint_fixture() {
  local source_db="$1"
  local destination_db="$2"
  local tmp

  tmp="$(mktemp "${TMPDIR:-/tmp}/canary-phoenix-fixture.XXXXXX.db")"
  sqlite3 "$source_db" "PRAGMA wal_checkpoint(TRUNCATE);"
  cp "$source_db" "$tmp"
  sqlite3 "$tmp" "PRAGMA wal_checkpoint(TRUNCATE); VACUUM;"
  cp "$tmp" "$destination_db"
  chmod 0644 "$destination_db"
  rm -f "$tmp" "$tmp-shm" "$tmp-wal" "$destination_db-shm" "$destination_db-wal"
}

rm -f "$test_db" "$test_db-shm" "$test_db-wal"
MIX_ENV=test MIX_TEST_PARTITION="$test_partition" mix ecto.create --quiet
MIX_ENV=test MIX_TEST_PARTITION="$test_partition" mix ecto.migrate --quiet

mkdir -p "$(dirname "$fixture")"
checkpoint_fixture "$test_db" "$fixture"

MIX_ENV=test MIX_TEST_PARTITION="$test_partition" mix run --no-start priv/repo/fixtures/rust_read_model_fixture.exs
checkpoint_fixture "$test_db" "$populated_fixture"

rm -f "$test_db" "$test_db-shm" "$test_db-wal"

echo "Regenerated $fixture"
echo "Regenerated $populated_fixture"

#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "${BASH_SOURCE[0]%/*}/.." && pwd)"
MANIFEST="${CANARY_DOGFOOD_MANIFEST:-$ROOT/.canary/dogfood/owned_services.json}"
WINDOW="24h"
NOW=""
MAX_EVIDENCE_AGE_HOURS=168
ENDPOINT="${CANARY_ENDPOINT:-}"
API_KEY="${CANARY_API_KEY:-}"
STRICT=0
JSON_OUTPUT=0

usage() {
  cat <<'EOF'
Usage: bin/dogfood-audit [--endpoint <url>] [--api-key <key>] [--window <window>] [--manifest <path>] [--now <rfc3339>] [--max-evidence-age-hours <hours>] [--strict] [--json] [-h|--help]

Audit Canary's deployed-service dogfood registry against a live Canary instance.

By default the command reads `CANARY_ENDPOINT`, `CANARY_API_KEY`, and the
instance-local registry at `.canary/dogfood/owned_services.json`. Set
`CANARY_DOGFOOD_MANIFEST` or pass `--manifest` to use another registry. The
command compares active HTTP services against live Canary targets, compares
active check-in services against live Canary monitors, and prints:

- Canary's current summary for the requested window
- every active service with target/monitor presence, health state, and errors
- pending, blocked, follow-on, suspended, and ignored services with next action
- extra live targets outside the deployed-service registry

`--json` emits the same audit as machine-readable JSON.
`--strict` exits non-zero when any active service coverage is missing,
duplicated, stale, or pointed at the wrong URL.
EOF
}

require_command() {
  local command_name="$1"

  if command -v "$command_name" >/dev/null 2>&1; then
    return 0
  fi

  printf 'Missing required command: %s\n' "$command_name" >&2
  exit 1
}

urlencode() {
  jq -nr --arg value "$1" '$value | @uri'
}

api_get() {
  local path="$1"
  curl -fsS -H "Authorization: Bearer $API_KEY" "${ENDPOINT%/}$path"
}

fail() {
  printf '%s\n' "$1" >&2
  exit 1
}

validate_manifest() {
  if ! jq -e '
    (.schema_version == 1) and
    (.services | type == "array") and
    (.services | length > 0) and
    (([.services[].service] | length) == ([.services[].service] | unique | length)) and
    all(.services[];
      (.service | type == "string" and length > 0) and
      (.state | IN("active", "pending", "blocked", "follow_on", "suspended", "ignored")) and
      (.platform | type == "string" and length > 0) and
      (has("production_url") and (.production_url == null or (.production_url | type == "string"))) and
      (has("health_url") and (.health_url == null or (.health_url | type == "string"))) and
      (.monitor_mode == null or (.monitor_mode | IN("http", "check_in", "external", "none"))) and
      (.last_checked_at | type == "string" and length > 0) and
      (.failure_mode | type == "string" and length > 0) and
      (.owner | type == "string" and length > 0) and
      (.next_action | type == "string" and length > 0)
    ) and
    all(.services[] | select(.state == "active");
      ((.monitor_mode // "http") == "check_in")
      or (.health_url | type == "string" and length > 0)
    )
  ' "$MANIFEST" >/dev/null; then
    fail "Invalid deployed-service registry: $MANIFEST"
  fi
}

service_registry_names() {
  jq -c '[.services[].service]' "$MANIFEST"
}

while (($#)); do
  case "$1" in
    --endpoint)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      ENDPOINT="$2"
      shift 2
      ;;
    --api-key)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      API_KEY="$2"
      shift 2
      ;;
    --window)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      WINDOW="$2"
      shift 2
      ;;
    --now)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      NOW="$2"
      shift 2
      ;;
    --max-evidence-age-hours)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      MAX_EVIDENCE_AGE_HOURS="$2"
      shift 2
      ;;
    --manifest)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      MANIFEST="$2"
      shift 2
      ;;
    --strict)
      STRICT=1
      shift
      ;;
    --json)
      JSON_OUTPUT=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

require_command curl
require_command jq

[[ -n "$ENDPOINT" ]] || fail "Missing Canary endpoint. Set CANARY_ENDPOINT or pass --endpoint."
[[ -n "$API_KEY" ]] || fail "Missing Canary API key. Set CANARY_API_KEY or pass --api-key."
[[ -f "$MANIFEST" ]] || fail "Manifest not found: $MANIFEST"
[[ "$MAX_EVIDENCE_AGE_HOURS" =~ ^[0-9]+$ ]] || fail "--max-evidence-age-hours must be a non-negative integer"
if [[ -z "$NOW" ]]; then
  require_command date
  NOW="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
fi
NOW_EPOCH="$(jq -nr --arg now "$NOW" 'try ($now | fromdateiso8601) catch empty')"
[[ -n "$NOW_EPOCH" ]] || fail "--now must be an RFC3339 UTC timestamp"

validate_manifest
DONE_BACKLOG_ITEMS="$(
  find "$ROOT/backlog.d/_done" -maxdepth 1 -type f -name '[0-9][0-9][0-9]-*.md' 2>/dev/null \
    | sed -E 's#.*/([0-9][0-9][0-9])-.*#\1#' \
    | jq -R . \
    | jq -s .
)"

targets_json="$(api_get "/api/v1/targets")"
report_json="$(api_get "/api/v1/report?window=$(urlencode "$WINDOW")")"
overall_summary="$(jq -r '.summary' <<<"$report_json")"
overall_status="$(jq -r '.status' <<<"$report_json")"

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
active_results="$tmpdir/active-results.ndjson"
: > "$active_results"

strict_failures=0
registry_policy_failures="$tmpdir/registry-policy-failures.ndjson"
: > "$registry_policy_failures"

jq -c \
  --argjson now_epoch "$NOW_EPOCH" \
  --argjson max_evidence_age_hours "$MAX_EVIDENCE_AGE_HOURS" \
  --argjson done_backlog_items "$DONE_BACKLOG_ITEMS" '
    def checked_epoch($value): try ($value | fromdateiso8601) catch null;
    def stale_evidence($svc):
      (checked_epoch($svc.last_checked_at)) as $checked
      | ($checked == null)
        or ($checked > $now_epoch)
        or (($now_epoch - $checked) > ($max_evidence_age_hours * 3600));
    def completed_ticket_reference($svc):
      ($svc.next_action // "") as $next
      | any($done_backlog_items[]; . as $done |
          ($next | test("(#0*" + $done + "\\b)|(ticket\\s+0*" + $done + "\\b)|(backlog items?\\b[^.\\n;]*\\b0*" + $done + "\\b)"; "i"))
        );
    .services[] as $svc
    | (
        if ($svc.state != "ignored" and stale_evidence($svc)) then
          {kind:"stale_registry_evidence", service:$svc.service, last_checked_at:$svc.last_checked_at}
        else empty end
      ),
      (
        if completed_ticket_reference($svc) then
          {kind:"completed_ticket_next_action", service:$svc.service, next_action:$svc.next_action}
        else empty end
      )
  ' "$MANIFEST" > "$registry_policy_failures"
strict_failures=$((strict_failures + $(wc -l < "$registry_policy_failures" | tr -d ' ')))

while IFS= read -r service_json; do
  service="$(jq -r '.service' <<<"$service_json")"
  expected_url="$(jq -r '.health_url // ""' <<<"$service_json")"
  monitor_mode="$(jq -r '.monitor_mode // (if (.health_url // "") != "" then "http" else "none" end)' <<<"$service_json")"
  encoded_service="$(urlencode "$service")"
  encoded_window="$(urlencode "$WINDOW")"
  query_json="$(api_get "/api/v1/query?service=${encoded_service}&window=${encoded_window}")"

  target_required=0
  monitor_required=0
  if [[ -n "$expected_url" ]]; then
    target_required=1
  fi
  if [[ "$monitor_mode" == "check_in" ]]; then
    monitor_required=1
  fi

  target_count="$(
    jq -r --arg service "$service" '
      [.targets[] | select(.service == $service)] | length
    ' <<<"$targets_json"
  )"

  actual_url="$(
    jq -r --arg service "$service" '
      [.targets[] | select(.service == $service) | .url][0] // ""
    ' <<<"$targets_json"
  )"

  health_state="$(
    jq -r --arg service "$service" '
      [.targets[] | select(.service == $service) | .state][0] // "missing"
    ' <<<"$report_json"
  )"

  monitor_count="$(
    jq -r --arg service "$service" '
      [.monitors[]? | select(.service == $service)] | length
    ' <<<"$report_json"
  )"

  monitor_state="$(
    jq -r --arg service "$service" '
      [.monitors[]? | select(.service == $service) | .state][0] // "missing"
    ' <<<"$report_json"
  )"

  monitor_name="$(
    jq -r --arg service "$service" '
      [.monitors[]? | select(.service == $service) | .name][0] // ""
    ' <<<"$report_json"
  )"

  last_check_in_at="$(
    jq -r --arg service "$service" '
      [.monitors[]? | select(.service == $service) | .last_check_in_at][0] // ""
    ' <<<"$report_json"
  )"

  total_errors="$(jq -r '.total_errors // 0' <<<"$query_json")"
  summary="$(jq -r '.summary // ""' <<<"$query_json")"

  target_state="n/a"
  url_state="n/a"
  monitor_state_label="n/a"

  if ((target_required == 1)); then
    target_state="present"
    url_state="yes"

    if [[ "$target_count" == "0" ]]; then
      target_state="missing"
      url_state="n/a"
      strict_failures=$((strict_failures + 1))
    elif [[ "$target_count" != "1" ]]; then
      target_state="duplicate"
      url_state="no"
      strict_failures=$((strict_failures + 1))
    elif [[ "$actual_url" != "$expected_url" ]]; then
      url_state="no"
      strict_failures=$((strict_failures + 1))
    elif [[ "$health_state" == "missing" ]]; then
      target_state="unobserved"
      strict_failures=$((strict_failures + 1))
    fi
  else
    actual_url=""
    health_state="n/a"
  fi

  if ((monitor_required == 1)); then
    monitor_state_label="$monitor_state"

    if [[ "$monitor_count" == "0" ]]; then
      monitor_state_label="missing"
      strict_failures=$((strict_failures + 1))
    elif [[ -z "$last_check_in_at" ]]; then
      monitor_state_label="unobserved"
      strict_failures=$((strict_failures + 1))
    fi
  fi

  jq -cn \
    --argjson registry "$service_json" \
    --arg monitor_mode "$monitor_mode" \
    --arg target_state "$target_state" \
    --arg url_state "$url_state" \
    --arg actual_url "$actual_url" \
    --arg health_state "$health_state" \
    --arg monitor_state "$monitor_state_label" \
    --arg monitor_name "$monitor_name" \
    --arg last_check_in_at "$last_check_in_at" \
    --argjson total_errors "$total_errors" \
    --arg summary "$summary" \
    '{
      service: $registry.service,
      state: $registry.state,
      platform: $registry.platform,
      monitor_mode: $monitor_mode,
      production_url: $registry.production_url,
      expected_health_url: $registry.health_url,
      actual_health_url: $actual_url,
      target: $target_state,
      url: $url_state,
      health: $health_state,
      monitor: $monitor_state,
      monitor_name: $monitor_name,
      last_check_in_at: $last_check_in_at,
      total_errors: $total_errors,
      summary: $summary,
      owner: $registry.owner,
      next_action: $registry.next_action
    }' >> "$active_results"
done < <(jq -c '.services[] | select(.state == "active")' "$MANIFEST")

extra_targets="$(
  jq -r \
    --argjson registry "$(service_registry_names)" '
      .targets
      | map(select((.service as $service | $registry | index($service)) | not))
      | map({service, url})
    ' <<<"$targets_json"
)"

if ((JSON_OUTPUT == 1)); then
  jq -n \
    --arg window "$WINDOW" \
    --arg status "$overall_status" \
    --arg summary "$overall_summary" \
    --argjson registry "$(jq '.services' "$MANIFEST")" \
    --argjson active "$(jq -s '.' "$active_results")" \
    --argjson extra "$extra_targets" \
    --argjson registry_policy_failures "$(jq -s '.' "$registry_policy_failures")" \
    --argjson strict_failures "$strict_failures" \
    '{
      window: $window,
      status: $status,
      summary: $summary,
      strict_failures: $strict_failures,
      active_services: $active,
      registry: $registry,
      extra_targets: $extra,
      registry_policy_failures: $registry_policy_failures
    }'
else
  printf 'Canary dogfood audit (%s)\n' "$WINDOW"
  printf 'status: %s\n' "$overall_status"
  printf 'summary: %s\n' "$overall_summary"
  printf '\n'

  printf 'Active services\n'
  printf '%-18s %-9s %-8s %-10s %-10s %-6s %-8s %s\n' "service" "target" "url" "health" "monitor" "errors" "platform" "expected"
  printf '%-18s %-9s %-8s %-10s %-10s %-6s %-8s %s\n' "-------" "------" "---" "------" "-------" "------" "--------" "--------"

  while IFS= read -r result_json; do
    printf '%-18s %-9s %-8s %-10s %-10s %-6s %-8s %s\n' \
      "$(jq -r '.service' <<<"$result_json")" \
      "$(jq -r '.target' <<<"$result_json")" \
      "$(jq -r '.url' <<<"$result_json")" \
      "$(jq -r '.health' <<<"$result_json")" \
      "$(jq -r '.monitor' <<<"$result_json")" \
      "$(jq -r '.total_errors' <<<"$result_json")" \
      "$(jq -r '.platform' <<<"$result_json")" \
      "$(jq -r '.expected_health_url' <<<"$result_json")"
    printf '  %s\n' "$(jq -r '.summary' <<<"$result_json")"
  done < "$active_results"

  for state in pending blocked follow_on suspended ignored; do
    count="$(jq -r --arg state "$state" '[.services[] | select(.state == $state)] | length' "$MANIFEST")"
    if [[ "$count" == "0" ]]; then
      continue
    fi

    printf '\n%s services\n' "$state"
    printf '%-24s %-10s %-28s %s\n' "service" "platform" "production" "next_action"
    printf '%-24s %-10s %-28s %s\n' "-------" "--------" "----------" "-----------"

    while IFS= read -r service_json; do
      printf '%-24s %-10s %-28s %s\n' \
        "$(jq -r '.service' <<<"$service_json")" \
        "$(jq -r '.platform' <<<"$service_json")" \
        "$(jq -r '.production_url // "n/a"' <<<"$service_json")" \
        "$(jq -r '.next_action' <<<"$service_json")"
      printf '  %s\n' "$(jq -r '.failure_mode' <<<"$service_json")"
      health_url="$(jq -r '.health_url // empty' <<<"$service_json")"
      if [[ -n "$health_url" ]]; then
        printf '  expected: %s\n' "$health_url"
      fi
    done < <(jq -c --arg state "$state" '.services[] | select(.state == $state)' "$MANIFEST")
  done

  extra_count="$(jq -r 'length' <<<"$extra_targets")"

  printf '\nExtra live targets\n'
  if [[ "$extra_count" == "0" ]]; then
    printf 'none\n'
  else
    jq -r '.[] | "  \(.service) -> \(.url)"' <<<"$extra_targets"
  fi
fi

if ((STRICT == 1 && strict_failures > 0)); then
  if ((JSON_OUTPUT == 0)); then
    printf '\nStrict audit failed: %s active service coverage issue(s).\n' "$strict_failures" >&2
  fi
  exit 1
fi

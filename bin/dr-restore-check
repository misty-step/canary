#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$ROOT/bin/lib/dr.sh"

HOST="$(dr_default_host)"
CONTAINER="$(dr_default_container)"
DB_PATH="$(dr_default_db_path)"

usage() {
  cat <<'EOF'
Usage: bin/dr-restore-check [--host <ssh-target>] [--container <name>] [--db-path <path>] [-h|--help]

Run a non-destructive restore drill inside the remote Canary container by
restoring the replica to a temporary file and listing the recovered database.

This restores the replica to a temporary file and never overwrites the live database.
EOF
}

while (($#)); do
  case "$1" in
    --host)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      HOST="$2"
      shift 2
      ;;
    --container)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      CONTAINER="$2"
      shift 2
      ;;
    --db-path)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      DB_PATH="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

HOST="$(dr_require_host "$HOST")"
CONTAINER="$(dr_require_container "$CONTAINER")"
DB_PATH="$(dr_require_db_path "$DB_PATH")"
dr_require_command ssh

dr_container_ssh "$HOST" "$CONTAINER" "$(dr_restore_remote_command "$DB_PATH")"

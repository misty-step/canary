#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$ROOT/bin/lib/dr.sh"

HOST="$(dr_default_host)"
CONTAINER="$(dr_default_container)"

usage() {
  cat <<'EOF'
Usage: bin/dr-status [--host <ssh-target>] [--container <name>] [-h|--help]

Show the running Canary container's Litestream replication status on its host.

This is a read-only preflight. It exits non-zero when Litestream backup
configuration is missing or when the remote command cannot run.
EOF
}

while (($#)); do
  case "$1" in
    --host)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      HOST="$2"
      shift 2
      ;;
    --container)
      if (($# < 2)); then
        usage >&2
        exit 1
      fi
      CONTAINER="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

HOST="$(dr_require_host "$HOST")"
CONTAINER="$(dr_require_container "$CONTAINER")"
dr_require_command ssh

dr_container_ssh "$HOST" "$CONTAINER" "$(dr_status_remote_command)"

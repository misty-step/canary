#!/usr/bin/env bash
set -euo pipefail

SELF_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/$(basename "${BASH_SOURCE[0]}")"
TRANSPORT="${CANARY_DAGGER_DOCKER_TRANSPORT:-auto}"

usage() {
  cat <<'EOF'
Usage: bin/dagger <dagger-args...>

Repo-local Dagger wrapper.

- On macOS, the default transport is Colima over SSH.
- On Linux/CI, the installed Dagger CLI is used directly.

Environment:
  CANARY_DAGGER_DOCKER_TRANSPORT=auto|colima-ssh|direct
EOF
}

find_dagger_bin() {
  local path_entry candidate resolved
  IFS=':' read -r -a path_entries <<<"$PATH"

  for path_entry in "${path_entries[@]}"; do
    [[ -z "$path_entry" ]] && path_entry="."
    candidate="$path_entry/dagger"

    if [[ ! -x "$candidate" ]]; then
      continue
    fi

    resolved="$(cd "$(dirname "$candidate")" && pwd -P)/$(basename "$candidate")"

    if [[ "$resolved" == "$SELF_PATH" ]]; then
      continue
    fi

    printf '%s\n' "$candidate"
    return 0
  done

  return 1
}

require_colima() {
  if ! command -v colima >/dev/null 2>&1; then
    printf "Colima is required for repo-local Dagger execution on macOS. Install it and run 'colima start --runtime docker'.\n" >&2
    exit 1
  fi

  if [[ ! -f "${HOME}/.colima/ssh_config" ]]; then
    printf "Missing %s. Start Colima with 'colima start --runtime docker' before running repo-local validation.\n" "${HOME}/.colima/ssh_config" >&2
    exit 1
  fi

  if ! colima status >/dev/null 2>&1; then
    printf "Colima is not running. Start it with 'colima start --runtime docker' before running repo-local validation.\n" >&2
    exit 1
  fi
}

run_with_colima() {
  local dagger_bin="$1"
  shift

  local tmpdir
  local status=0
  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/canary-dagger.XXXXXX")"

  cat >"$tmpdir/docker" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

exec ssh -F "$HOME/.colima/ssh_config" -T colima docker "$@"
EOF

  chmod +x "$tmpdir/docker"
  PATH="$tmpdir:$PATH" "$dagger_bin" "$@" || status=$?
  rm -rf -- "$tmpdir"
  return "$status"
}

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 1
fi

case "$1" in
  -h|--help|help)
    usage
    exit 0
    ;;
esac

dagger_bin="$(find_dagger_bin || true)"

if [[ -z "$dagger_bin" ]]; then
  printf 'dagger CLI is required for repo validation. Install it before running hooks or validation.\n' >&2
  exit 1
fi

case "$TRANSPORT" in
  auto)
    if [[ "$(uname -s)" == "Darwin" ]]; then
      require_colima
      run_with_colima "$dagger_bin" "$@"
      exit $?
    fi

    exec "$dagger_bin" "$@"
    ;;
  colima-ssh)
    require_colima
    run_with_colima "$dagger_bin" "$@"
    ;;
  direct)
    exec "$dagger_bin" "$@"
    ;;
  *)
    printf 'Unknown CANARY_DAGGER_DOCKER_TRANSPORT value: %s\n' "$TRANSPORT" >&2
    exit 1
    ;;
esac

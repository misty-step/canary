#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODE=full

usage() {
  cat <<'EOF'
Usage: bin/validate [--fast|--advisories|--strict] [-h|--help]

Runs the canonical repo-local validation through Dagger.
  --fast        Run the reduced hook-oriented validation set.
  --advisories  Run live dependency advisory scans only.
  --strict      Run the deterministic gate followed by advisory scans.
  -h, --help    Show this help message.
EOF
}

while (($#)); do
  case "$1" in
    --fast)
      MODE=fast
      shift
      ;;
    --advisories)
      MODE=advisories
      shift
      ;;
    --strict)
      MODE=strict
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

if ! command -v dagger >/dev/null 2>&1; then
  printf 'dagger CLI is required for repo validation. Install it before running hooks or CI.\n' >&2
  exit 1
fi

cd "$ROOT"

if [[ "$MODE" == "fast" ]]; then
  exec dagger call --progress=plain fast
fi

if [[ "$MODE" == "advisories" ]]; then
  exec dagger call --progress=plain advisories
fi

if [[ "$MODE" == "strict" ]]; then
  dagger call --progress=plain codex-agent-roles
  dagger check --progress=plain
  exec dagger call --progress=plain advisories
fi

exec dagger check --progress=plain

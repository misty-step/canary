#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CI_MODE=0

. "$ROOT/bin/lib/docker_probe.sh"

require_command() {
  local command_name="$1"
  local help_text="$2"

  if command -v "$command_name" >/dev/null 2>&1; then
    return 0
  fi

  printf 'Missing required command: %s\n%s\n' "$command_name" "$help_text" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage: bin/bootstrap [--ci] [-h|--help]

Bootstraps every maintained package in the monorepo.
  --ci        Skip local git hook setup and honor explicit CI MIX_ENV.
  -h, --help  Show this help message.
EOF
}

note_colima() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    return 0
  fi

  if docker_available; then
    return 0
  fi

  if ! colima version >/dev/null 2>&1; then
    printf '==> tooling: macOS local validation needs a working Docker runtime. Start Docker Desktop or install/start Colima before running ./bin/validate.\n'
    return 0
  fi

  if ! colima status >/dev/null 2>&1; then
    printf '==> tooling: no working Docker runtime detected. If you use Colima, start it before running local validation: colima start --runtime docker\n'
  fi
}

while (($#)); do
  case "$1" in
    --ci)
      CI_MODE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

if [[ "$CI_MODE" -eq 0 ]]; then
  require_command "dagger" "Install the Dagger CLI before relying on repo hooks or validation."
  note_colima
fi

run() {
  local dir="$1"
  shift

  printf '==> %s: %s\n' "$dir" "$*"
  (
    cd "$ROOT/$dir"
    "$@"
  )
}

run_mix() {
  local dir="$1"
  shift
  local mix_env=dev

  if [[ "$CI_MODE" -eq 1 ]] && [[ -n "${MIX_ENV:-}" ]]; then
    mix_env="$MIX_ENV"
  fi

  run "$dir" env MIX_ENV="$mix_env" "$@"
}

run_mix "." mix setup
run_mix "canary_sdk" mix deps.get
run "clients/typescript" npm ci

if [[ "$CI_MODE" -eq 0 ]] && git -C "$ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git -C "$ROOT" config core.hooksPath .githooks
  printf '==> hooks: configured core.hooksPath=.githooks\n'
fi
